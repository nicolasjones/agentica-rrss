# ===========================================
# AGENMATICA - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# Keys marked [MOCK] can be left empty for development

# --- App ---
APP_NAME=AGENMATICA
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
API_VERSION=v1
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# --- Database ---
DATABASE_URL=postgresql+asyncpg://agenmatica:agenmatica@localhost:5432/agenmatica
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Celery / RabbitMQ ---
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- JWT Auth ---
JWT_SECRET_KEY=change-me-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Together.ai (LLM) [MOCK] ---
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-2-13b-chat-hf
TOGETHER_MAX_TOKENS=1024
TOGETHER_TEMPERATURE=0.7

# --- Replicate (Image Gen) [MOCK] ---
REPLICATE_API_TOKEN=
REPLICATE_MODEL=black-forest-labs/flux-pro

# --- Instagram Graph API [MOCK] ---
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_REDIRECT_URI=http://localhost:8000/api/v1/auth/instagram/callback

# --- TikTok API [MOCK] ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# --- Stripe [MOCK] ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- SendGrid [MOCK] ---
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@agenmatica.com

# --- Sentry (Error Tracking) [MOCK] ---
SENTRY_DSN=

# --- Feature Flags ---
MOCK_LLM=true
MOCK_SOCIAL_APIS=true
MOCK_IMAGE_GEN=true
MOCK_PAYMENTS=true
MOCK_EMAIL=true

# --- Post Generation ---
POSTS_PER_DAY=5
POST_GENERATION_HOUR=8
ENGAGEMENT_ANALYSIS_HOUR=21
LEARNING_LOOP_DAY=sunday

# --- Embedding ---
EMBEDDING_DIMENSIONS=1536
